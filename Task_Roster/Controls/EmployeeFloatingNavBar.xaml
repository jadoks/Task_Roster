<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Task_Roster.Controls.EmployeeFloatingNavBar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid HeightRequest="130" Padding="24,0,24,24" VerticalOptions="End">

        <Border
            HeightRequest="78"
            BackgroundColor="White"
            StrokeThickness="0"
            VerticalOptions="End">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="39" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,*" Padding="48,8">

                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <ImageButton
                        x:Name="HomeButton"
                        Source="home.svg"
                        BackgroundColor="Transparent"
                        WidthRequest="28"
                        HeightRequest="28"
                        Padding="4"
                        Clicked="HomeClicked" />

                    <Label
                        x:Name="HomeLabel"
                        Text="Home"
                        FontSize="10"
                        TextColor="#8A8A8A" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                    <ImageButton
                        x:Name="SettingsButton"
                        Source="settings.svg"
                        BackgroundColor="Transparent"
                        WidthRequest="28"
                        HeightRequest="28"
                        Padding="4"
                        Clicked="SettingsClicked" />

                    <Label
                        x:Name="SettingsLabel"
                        Text="Settings"
                        FontSize="10"
                        TextColor="#8A8A8A" />
                </VerticalStackLayout>

            </Grid>
        </Border>

        <Border
            x:Name="Indicator"
            WidthRequest="62"
            HeightRequest="62"
            BackgroundColor="#8DFF2F"
            StrokeThickness="0"
            HorizontalOptions="Start"
            VerticalOptions="Start">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="31" />
            </Border.StrokeShape>

            <Image
                x:Name="IndicatorIcon"
                Source="home.svg"
                WidthRequest="25"
                HeightRequest="25"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Border>

    </Grid>
</ContentView>