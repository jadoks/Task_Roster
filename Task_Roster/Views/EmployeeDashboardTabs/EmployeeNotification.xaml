<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Task_Roster.Views.EmployeeDashboardTabs.EmployeeNotification"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F5F6F8"
    NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid
            Padding="8,8,14,10"
            ColumnDefinitions="Auto,*,Auto"
            BackgroundColor="White">

            <Button
                Text="‹"
                FontSize="34"
                BackgroundColor="Transparent"
                TextColor="#374151"
                Padding="0"
                WidthRequest="32"
                Clicked="OnBackClicked" />

            <Label
                Grid.Column="1"
                Text="Notifications"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#1F2937"
                VerticalOptions="Center" />

            
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1">

            <CollectionView
                x:Name="NotificationsList"
                IsVisible="True"
                SelectionMode="None"
                Margin="6,16,12,24">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="8">

                            <Label
                                Text="{Binding DateLabel}"
                                FontSize="12"
                                TextColor="#6B7280"
                                Margin="0,0,0,4"
                                IsVisible="{Binding ShowDateHeader}" />

                            <Border
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                Padding="14"
                                Margin="0,0,0,8"
                                StrokeThickness="1">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                    <Border
                                        WidthRequest="32"
                                        HeightRequest="32"
                                        BackgroundColor="{Binding IconBackgroundColor}"
                                        StrokeThickness="0"
                                        VerticalOptions="Start">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>

                                        <Image
                                            Source="{Binding IconSource}"
                                            WidthRequest="16"
                                            HeightRequest="16"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                                        <Label
                                            Text="{Binding Title}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="#111827" />

                                        <Label
                                            Text="{Binding Message}"
                                            FontSize="12"
                                            TextColor="#6B7280"
                                            LineHeight="1.3" />
                                    </VerticalStackLayout>

                                    <Label
                                        Grid.Column="2"
                                        Text="{Binding TimeLabel}"
                                        FontSize="10"
                                        TextColor="#6B7280"
                                        VerticalOptions="Start" />
                                </Grid>
                            </Border>

                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <VerticalStackLayout
                x:Name="EmptyState"
                IsVisible="False"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="8">

                <Label
                    Text="🔔"
                    FontSize="34"
                    HorizontalTextAlignment="Center" />

                <Label
                    Text="No notifications yet"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="#111827"
                    HorizontalTextAlignment="Center" />

                <Label
                    Text="Assigned shifts and tasks will appear here."
                    FontSize="12"
                    TextColor="#6B7280"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>