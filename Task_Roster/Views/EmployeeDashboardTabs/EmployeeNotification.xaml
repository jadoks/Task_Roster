<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Task_Roster.Views.EmployeeDashboardTabs.EmployeeNotification"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F5F6F8"
    NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid
            Padding="8,8,14,10"
            ColumnDefinitions="Auto,*,Auto"
            BackgroundColor="White">

            <Button
                Text="‹"
                FontSize="34"
                BackgroundColor="Transparent"
                TextColor="#374151"
                Padding="0"
                WidthRequest="32"
                Clicked="OnBackClicked" />

            <Label
                Grid.Column="1"
                Text="Notifications"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#1F2937"
                VerticalOptions="Center" />

            <Image
                Grid.Column="2"
                Source="bell.svg"
                WidthRequest="22"
                HeightRequest="22"
                VerticalOptions="Center" />
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="6,16,12,24" Spacing="10">

                <Label
                    Text="September 19, 2025"
                    FontSize="12"
                    TextColor="#6B7280"
                    Margin="0,0,0,4" />

                <!-- Notification 1 -->
                <Border
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    Padding="14"
                    Margin="0"
                    StrokeThickness="1">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                        <Border
                            WidthRequest="32"
                            HeightRequest="32"
                            BackgroundColor="#DBEAFE"
                            StrokeThickness="0"
                            VerticalOptions="Start">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <Image
                                Source="calendar.svg"
                                WidthRequest="16"
                                HeightRequest="16"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label
                                Text="New Shift Assigned"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#111827" />

                            <Label
                                Text="You have been assigned a shift on Monday from 9 AM to 5 PM"
                                FontSize="12"
                                TextColor="#6B7280"
                                LineHeight="1.3" />
                        </VerticalStackLayout>

                        <Label
                            Grid.Column="2"
                            Text="10:46 PM"
                            FontSize="10"
                            TextColor="#6B7280"
                            VerticalOptions="Start" />
                    </Grid>
                </Border>

                <!-- Notification 2 -->
                <Border
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    Padding="14"
                    Margin="0"
                    StrokeThickness="1">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                        <Border
                            WidthRequest="32"
                            HeightRequest="32"
                            BackgroundColor="#DCFCE7"
                            StrokeThickness="0"
                            VerticalOptions="Start">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <Image
                                Source="clipboard.svg"
                                WidthRequest="16"
                                HeightRequest="16"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label
                                Text="Task Reminder"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#111827" />

                            <Label
                                Text="Task &quot;Clean store front&quot; is due in 2 hours"
                                FontSize="12"
                                TextColor="#6B7280"
                                LineHeight="1.3" />
                        </VerticalStackLayout>

                        <Label
                            Grid.Column="2"
                            Text="10:46 PM"
                            FontSize="10"
                            TextColor="#6B7280"
                            VerticalOptions="Start" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>