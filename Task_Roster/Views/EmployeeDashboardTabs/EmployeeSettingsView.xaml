<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Task_Roster.Views.EmployeeDashboardTabs.EmployeeSettingsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Padding="24,40,24,120" Spacing="18">
        <Label
            Text="Settings"
            FontSize="24"
            FontAttributes="Bold"
            TextColor="#111827" />

        <Button
            Text="Logout"
            BackgroundColor="#EF4444"
            TextColor="White"
            CornerRadius="8"
            Clicked="OnLogoutClicked" />
    </VerticalStackLayout>
</ContentView>