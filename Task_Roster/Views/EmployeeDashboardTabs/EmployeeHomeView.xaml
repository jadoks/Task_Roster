<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Task_Roster.Views.EmployeeDashboardTabs.EmployeeHomeView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="22,18,22,120" Spacing="20">

            <Grid ColumnDefinitions="*,Auto">
                <Label
                    Text="My Schedule"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="#111827" />

                <Image
                    Grid.Column="1"
                    Source="bell.svg"
                    WidthRequest="24"
                    HeightRequest="24" />
            </Grid>

            <VerticalStackLayout Spacing="2">
                <Label
                    x:Name="GreetingLabel"
                    Text="Hi, Employee"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="#111827" />

                <Label
                    x:Name="DateLabel"
                    Text=""
                    FontSize="14"
                    TextColor="#6B7280" />
            </VerticalStackLayout>

            <Label Text="Today's Shifts" FontSize="17" FontAttributes="Bold" TextColor="#111827" />

            <Border BackgroundColor="White" Stroke="#E5E7EB" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="No shifts scheduled for today" FontSize="14" TextColor="#6B7280" HorizontalTextAlignment="Center" />
                    <Label Text="Enjoy your day off!" FontSize="12" TextColor="#9CA3AF" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Border BackgroundColor="White" Stroke="#E5E7EB" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border BackgroundColor="#E8F5EE" WidthRequest="36" HeightRequest="36">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Image Source="schedule.svg" WidthRequest="20" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="This Week" FontSize="12" TextColor="#6B7280" />
                            <Label Text="2 shifts" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Grid.Column="1" BackgroundColor="White" Stroke="#E5E7EB" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border BackgroundColor="#DCFCE7" WidthRequest="36" HeightRequest="36">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Image Source="check.svg" WidthRequest="20" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Tasks" FontSize="12" TextColor="#6B7280" />
                            <Label Text="0/2" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </Grid>

            <Label Text="Upcoming Shifts" FontSize="17" FontAttributes="Bold" TextColor="#111827" />

            <Border BackgroundColor="White" Stroke="#E5E7EB" Padding="28">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <Label Text="No upcoming shifts scheduled" FontSize="14" TextColor="#6B7280" HorizontalTextAlignment="Center" />
            </Border>

            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Tasks To Complete" FontSize="17" FontAttributes="Bold" TextColor="#111827" />

                <Border Grid.Column="1" BackgroundColor="#E8F5EE" WidthRequest="24" HeightRequest="24">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <Label Text="2" FontSize="12" TextColor="{StaticResource PrimaryGreen}" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>

            <Border BackgroundColor="White" Stroke="#E5E7EB" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Clean store front" FontSize="15" TextColor="#111827" />
                        <Label Text="Sweep and mop the entrance area" FontSize="13" TextColor="#6B7280" />
                    </VerticalStackLayout>

                    <Border Grid.Column="1" BackgroundColor="#FEF3C7" Padding="10,5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Label Text="medium" FontSize="11" TextColor="#B45309" />
                    </Border>
                </Grid>
            </Border>

            <Border BackgroundColor="White" Stroke="#E5E7EB" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Daily cash count" FontSize="15" TextColor="#111827" />
                        <Label Text="Count the cash register and record totals" FontSize="13" TextColor="#6B7280" />
                    </VerticalStackLayout>

                    <Border Grid.Column="1" BackgroundColor="#FEE2E2" Padding="10,5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Label Text="high" FontSize="11" TextColor="#DC2626" />
                    </Border>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>