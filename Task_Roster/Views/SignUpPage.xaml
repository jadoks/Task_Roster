<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Task_Roster.Views.SignUpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="White"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid Padding="28" RowDefinitions="*,Auto,*">

            <VerticalStackLayout Grid.Row="1" Spacing="20">

                <Label
                    Text="TaskRoster"
                    FontSize="54"
                    FontAttributes="Bold"
                    TextColor="{StaticResource PrimaryGreen}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,18" />

                <Label
                    Text="Create your Account"
                    FontSize="19"
                    FontAttributes="Bold"
                    TextColor="{StaticResource PrimaryGreen}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,18" />

                <Border Stroke="{StaticResource BorderGreen}" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>

                    <Entry
                        x:Name="EmailEntry"
                        Placeholder="Email"
                        Keyboard="Email"
                        HeightRequest="36"
                        FontSize="12"
                        Margin="10,0" />
                </Border>

                <Border Stroke="{StaticResource BorderGreen}" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>

                    <Entry
                        x:Name="FirstNameEntry"
                        Placeholder="First Name"
                        HeightRequest="36"
                        FontSize="12"
                        Margin="10,0" />
                </Border>

                <Border Stroke="{StaticResource BorderGreen}" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>

                    <Entry
                        x:Name="LastNameEntry"
                        Placeholder="Last Name"
                        HeightRequest="36"
                        FontSize="12"
                        Margin="10,0" />
                </Border>

                <Border Stroke="{StaticResource BorderGreen}" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="*,Auto">
                        <Entry
                            x:Name="PasswordEntry"
                            Placeholder="Password"
                            IsPassword="True"
                            HeightRequest="36"
                            FontSize="12"
                            Margin="10,0" />

                        <ImageButton
                            x:Name="PasswordToggleButton"
                            Grid.Column="1"
                            Source="eyeslash.svg"
                            BackgroundColor="Transparent"
                            WidthRequest="36"
                            HeightRequest="36"
                            Padding="8"
                            Clicked="OnTogglePasswordClicked" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,Auto,*" Margin="10,-6,10,-10">
                    <BoxView HeightRequest="1" Color="#A3A3A3" VerticalOptions="Center" />

                    <Label
                        Grid.Column="1"
                        Text="Select your Role"
                        FontSize="10"
                        TextColor="#7A7A7A"
                        Margin="10,0" />

                    <BoxView
                        Grid.Column="2"
                        HeightRequest="1"
                        Color="#A3A3A3"
                        VerticalOptions="Center" />
                </Grid>

                <Grid ColumnDefinitions="*,30,*">
                    <Button
                        x:Name="ManagerButton"
                        Text="Manager"
                        FontSize="12"
                        HeightRequest="34"
                        CornerRadius="7"
                        BackgroundColor="#DCE5E0"
                        TextColor="{StaticResource PrimaryGreen}"
                        BorderColor="{StaticResource PrimaryGreen}"
                        BorderWidth="1"
                        Clicked="OnManagerClicked" />

                    <Button
                        x:Name="EmployeeButton"
                        Grid.Column="2"
                        Text="Employee"
                        FontSize="12"
                        HeightRequest="34"
                        CornerRadius="7"
                        BackgroundColor="#DCE5E0"
                        TextColor="{StaticResource PrimaryGreen}"
                        BorderColor="{StaticResource PrimaryGreen}"
                        BorderWidth="1"
                        Clicked="OnEmployeeClicked" />
                </Grid>

                <Button
                    Text="Register"
                    HeightRequest="48"
                    CornerRadius="7"
                    BackgroundColor="{StaticResource PrimaryGreen}"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="0,10,0,0"
                    Clicked="OnRegisterClicked" />

                <Button
                    Text="Login"
                    HeightRequest="48"
                    CornerRadius="7"
                    BackgroundColor="White"
                    TextColor="{StaticResource PrimaryGreen}"
                    FontSize="16"
                    FontAttributes="Bold"
                    BorderColor="{StaticResource PrimaryGreen}"
                    BorderWidth="1"
                    Clicked="OnLoginClicked" />

            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>