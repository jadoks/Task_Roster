<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Task_Roster.Views.DashboardTabs.ScheduleView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F5F6F8">

    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="16,18,16,24" Spacing="18">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto" Padding="0,0,0,10">
                    <Label
                    Text="Schedule Editor"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="#1F2937"
                    VerticalOptions="Center" />

                   <Image
                    Grid.Column="1"
                    Source="bell.svg"
                    WidthRequest="22"
                    HeightRequest="22"
                    VerticalOptions="Center" />
                </Grid>

                <!-- Week Navigation -->
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,8">
                    <Button
                        Text="‹"
                        FontSize="26"
                        BackgroundColor="Transparent"
                        TextColor="#111827"
                        Clicked="OnPreviousWeekClicked" />

                    <Label
                        x:Name="WeekRangeLabel"
                        Grid.Column="1"
                        Text="Sep 14  -  Sep 20"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="#111827"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />

                    <Button
                        Grid.Column="2"
                        Text="›"
                        FontSize="26"
                        BackgroundColor="Transparent"
                        TextColor="#111827"
                        Clicked="OnNextWeekClicked" />
                </Grid>

                <!-- Action Buttons -->
                <HorizontalStackLayout Spacing="10">
                    <Button
                        Text="+  Add Shift"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        CornerRadius="6"
                        FontSize="13"
                        Padding="16,10"
                        Clicked="OnAddShiftClicked" />

                    <Button
                        Text="⚡  Auto Assign"
                        BackgroundColor="#16A34A"
                        TextColor="White"
                        CornerRadius="6"
                        FontSize="13"
                        Padding="16,10"
                        Clicked="OnAutoAssignClicked" />
                </HorizontalStackLayout>

                <!-- Days Header -->
                <Grid
                    x:Name="DaysHeaderGrid"
                    ColumnDefinitions="*,*,*,*,*,*,*"
                    ColumnSpacing="6" />

                <!-- Schedule Cards -->
                <Grid
                    x:Name="ScheduleGrid"
                    ColumnDefinitions="*,*,*,*,*,*,*"
                    ColumnSpacing="6"
                    Margin="0,8,0,0" />

                <!-- Shift Details -->
                <Border
                    x:Name="ShiftDetailsCard"
                    IsVisible="False"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    Padding="14"
                    Margin="0,18,0,0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                x:Name="DetailsRoleLabel"
                                Text="cashier"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#111827" />

                            <Border
                                Grid.Column="1"
                                BackgroundColor="#FEF3C7"
                                Padding="10,4"
                                StrokeThickness="0">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>

                                <Label
                                    x:Name="DetailsStatusLabel"
                                    Text="Pending"
                                    FontSize="10"
                                    TextColor="#CA8A04" />
                            </Border>
                        </Grid>

                        <Label x:Name="DetailsDateLabel" FontSize="12" TextColor="#4B5563" />
                        <Label x:Name="DetailsTimeLabel" FontSize="12" TextColor="#4B5563" />
                        <Label x:Name="DetailsLocationLabel" FontSize="12" TextColor="#4B5563" />

                        <BoxView HeightRequest="1" Color="#E5E7EB" />

                        <Label Text="Assigned to:" FontSize="12" TextColor="#6B7280" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Border
                                WidthRequest="38"
                                HeightRequest="38"
                                BackgroundColor="#DBEAFE"
                                StrokeThickness="0">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="19" />
                                </Border.StrokeShape>

                                <Label
                                    Text="👤"
                                    FontSize="20"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1">
                                <Label x:Name="DetailsEmployeeLabel" FontSize="13" FontAttributes="Bold" TextColor="#111827" />
                                <Label Text="john@example.com" FontSize="11" TextColor="#6B7280" />
                            </VerticalStackLayout>
                        </Grid>

                        <Border BackgroundColor="White" Stroke="#E5E7EB" Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Tasks" FontSize="14" FontAttributes="Bold" TextColor="#111827" />
                                    <Label x:Name="TaskCountLabel" Grid.Column="1" Text="0/1 completed" FontSize="11" TextColor="#6B7280" />
                                </Grid>

                                <Border BackgroundColor="#FEFCE8" StrokeThickness="0" Padding="10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>

                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                        <CheckBox x:Name="TaskCheckBox" CheckedChanged="OnTaskCheckedChanged" />
                                        <Label Grid.Column="1" Text="Gwapo" FontSize="12" TextColor="#111827" VerticalOptions="Center" />

                                        <Border Grid.Column="2" BackgroundColor="#FEF3C7" Padding="8,3" StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8" />
                                            </Border.StrokeShape>
                                            <Label Text="medium" FontSize="9" TextColor="#CA8A04" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <Button
                                    Text="+ Add Task"
                                    FontSize="12"
                                    BackgroundColor="White"
                                    TextColor="#2563EB"
                                    BorderColor="#E5E7EB"
                                    BorderWidth="1"
                                    CornerRadius="4"
                                    Clicked="OnAddTaskClicked" />
                            </VerticalStackLayout>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button
                                Text="✓  Accept"
                                BackgroundColor="#16A34A"
                                TextColor="White"
                                CornerRadius="4"
                                Clicked="OnAcceptClicked" />

                            <Button
                                Grid.Column="1"
                                Text="✕  Decline"
                                BackgroundColor="#DC2626"
                                TextColor="White"
                                CornerRadius="4"
                                Clicked="OnDeclineClicked" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Add Shift Modal -->
        <Grid
            x:Name="AddShiftOverlay"
            IsVisible="False"
            BackgroundColor="#99000000"
            Padding="20">

            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="14"
                VerticalOptions="Center">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="14">

                    <Label Text="Add New Shift" FontSize="16" FontAttributes="Bold" TextColor="#111827" />

                    <BoxView HeightRequest="1" Color="#E5E7EB" />

                    <Label Text="Date" FontSize="12" TextColor="#374151" />
                    <DatePicker x:Name="ShiftDatePicker" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout>
                            <Label Text="Start Time" FontSize="12" TextColor="#374151" />
                            <TimePicker x:Name="StartTimePicker" Time="09:00:00" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="End Time" FontSize="12" TextColor="#374151" />
                            <TimePicker x:Name="EndTimePicker" Time="17:00:00" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Role Needed" FontSize="12" TextColor="#374151" />
                    <Picker x:Name="RolePicker">
                        <Picker.Items>
                            <x:String>Cashier</x:String>
                            <x:String>Manager</x:String>
                            <x:String>Stock Clerk</x:String>
                            <x:String>Security</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="Location" FontSize="12" TextColor="#374151" />
                    <Picker x:Name="LocationPicker">
                        <Picker.Items>
                            <x:String>Downtown Store</x:String>
                            <x:String>Main Branch</x:String>
                            <x:String>North Branch</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="Assign Employee Optional" FontSize="12" TextColor="#374151" />
                    <Picker x:Name="EmployeePicker">
                        <Picker.Items>
                            <x:String>-- Unassigned --</x:String>
                            <x:String>John Smith</x:String>
                            <x:String>David Lee</x:String>
                            <x:String>Maria Santos</x:String>
                        </Picker.Items>
                    </Picker>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                        <Button
                            Text="Cancel"
                            BackgroundColor="White"
                            TextColor="#6B7280"
                            BorderColor="#E5E7EB"
                            BorderWidth="1"
                            Clicked="OnCancelAddShiftClicked" />

                        <Button
                            Grid.Column="1"
                            Text="Create Shift"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            Clicked="OnCreateShiftClicked" />
                    </Grid>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Confirm Modal -->
        <Grid
            x:Name="ConfirmOverlay"
            IsVisible="False"
            BackgroundColor="#99000000"
            Padding="20">

            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16"
                VerticalOptions="Center">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">
                    <Label Text="Confirm New Shift" FontSize="16" FontAttributes="Bold" TextColor="#111827" />

                    <BoxView HeightRequest="1" Color="#E5E7EB" />

                    <Label Text="Please review the shift details before confirming:" FontSize="12" TextColor="#6B7280" />

                    <Border BackgroundColor="#EFF6FF" StrokeThickness="0" Padding="14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <Label x:Name="ConfirmDateLabel" FontSize="12" TextColor="#374151" />
                            <Label x:Name="ConfirmTimeLabel" FontSize="12" TextColor="#374151" />
                            <Label x:Name="ConfirmLocationLabel" FontSize="12" TextColor="#374151" />
                            <Label x:Name="ConfirmRoleLabel" FontSize="12" TextColor="#374151" />
                            <Label x:Name="ConfirmEmployeeLabel" FontSize="12" TextColor="#374151" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button
                            Text="✕ Edit"
                            BackgroundColor="White"
                            TextColor="#374151"
                            BorderColor="#E5E7EB"
                            BorderWidth="1"
                            Clicked="OnEditShiftClicked" />

                        <Button
                            Grid.Column="1"
                            Text="✓ Confirm &amp; Create"
                            BackgroundColor="#166534"
                            TextColor="White"
                            Clicked="OnConfirmCreateClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
        <!-- Place this at the very bottom of your main Grid, after all other Borders/Grids -->
        <Grid
    x:Name="AddTaskOverlay"
    IsVisible="False"
    BackgroundColor="#99000000"
    HorizontalOptions="Fill"
    VerticalOptions="Fill">

            <Border
        BackgroundColor="White"
        StrokeThickness="0"
        VerticalOptions="Center"
        HorizontalOptions="Center"
        WidthRequest="350"
        Padding="0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">
                    <!-- Header -->
                    <Label 
                Text="Add New Task" 
                FontSize="18" 
                FontAttributes="Bold" 
                TextColor="#111827" 
                Padding="20,18" />

                    <BoxView HeightRequest="1" Color="#E5E7EB" />

                    <VerticalStackLayout Padding="20" Spacing="16">
                        <!-- Task Title -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Task Title" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                            <Entry x:Name="TaskTitleEntry" Placeholder="Enter title" TextColor="#111827" />
                        </VerticalStackLayout>

                        <!-- Description -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Description" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                            <Editor x:Name="TaskDescriptionEditor" HeightRequest="100" Placeholder="Enter description" />
                        </VerticalStackLayout>

                        <!-- Priority -->
                        <!-- Priority Section inside AddTaskOverlay -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Priority" FontSize="12" FontAttributes="Bold" TextColor="#374151" />

                            <!-- Use a Grid with * columns to force them to share the width equally -->
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" HorizontalOptions="Fill">
                                <Button x:Name="LowPriorityBtn" 
                                        Grid.Column="0"
                                        Text="Low" 
                                        Clicked="OnPrioritySelectionClicked" 
                                        BackgroundColor="#F3F4F6" 
                                        TextColor="#374151" 
                                        HeightRequest="40"
                                        Padding="0"
                                        CornerRadius="6" />
                                <Button x:Name="MediumPriorityBtn" 
                                        Grid.Column="1"
                                        Text="Medium" 
                                        Clicked="OnPrioritySelectionClicked" 
                                        BackgroundColor="#FEF3C7" 
                                        TextColor="#CA8A04" 
                                        HeightRequest="40"
                                        Padding="0"
                                        CornerRadius="6" />
                                <Button x:Name="HighPriorityBtn" 
                                        Grid.Column="2"
                                        Text="High" 
                                        Clicked="OnPrioritySelectionClicked" 
                                        BackgroundColor="#F3F4F6" 
                                        TextColor="#374151" 
                                        HeightRequest="40"
                                        Padding="0"
                                        CornerRadius="6" />
                            </Grid>
                        </VerticalStackLayout>
                        <!-- Footer Buttons -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                            <Button
                        Text="Cancel"
                        BackgroundColor="White"
                        TextColor="#374151"
                        BorderColor="#E5E7EB"
                        BorderWidth="1"
                        CornerRadius="8"
                        Clicked="OnCancelAddTaskClicked" />

                            <Button
                        Grid.Column="1"
                        Text="Add Task"
                        BackgroundColor="#16A34A"
                        TextColor="White"
                        CornerRadius="8"
                        Clicked="OnSubmitTaskClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
        <!-- Task Details Overlay -->
        <Grid
    x:Name="TaskDetailsOverlay"
    IsVisible="False"
    BackgroundColor="#F5F6F8"
    Padding="16">

            <VerticalStackLayout Spacing="20">
                <!-- Custom Header -->
                <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Start">
                    <Button Text="←" BackgroundColor="Transparent" TextColor="#1F2937" FontSize="24" Clicked="OnCloseTaskDetailsClicked" />
                    <Label Grid.Column="1" Text="Task Details" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Image Grid.Column="2" Source="bell.svg" WidthRequest="24" />
                </Grid>

                <!-- Main Task Card -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label x:Name="ViewTaskTitle" Text="Gwapo" FontSize="18" FontAttributes="Bold" />
                            <Border Grid.Column="1" BackgroundColor="#FEF9C3" Padding="8,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label x:Name="ViewTaskPriority" Text="medium priority" TextColor="#854D0E" FontSize="11" />
                            </Border>
                        </Grid>

                        <Label x:Name="ViewTaskDue" Text="🕒 Due: Oct 24, 5:00 PM" TextColor="#6B7280" FontSize="13" />
                        <BoxView HeightRequest="1" Color="#F3F4F6" Margin="0,5" />
                        <Label x:Name="ViewTaskDescription" Text="pogi" TextColor="#374151" FontSize="14" />
                    </VerticalStackLayout>
                </Border>

                <!-- Shift Details Card -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Details" FontSize="16" FontAttributes="Bold" />

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                            <Label Text="Assigned to:" TextColor="#6B7280" WidthRequest="100" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                <Label Text="👤" />
                                <Label x:Name="ViewAssignedStaff" Text="John Smith" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                            <Label Text="Shift:" TextColor="#6B7280" WidthRequest="100" />
                            <Label x:Name="ViewShiftTime" Grid.Column="1" Text="Fri, Oct 24, 09:00 - 17:00" FontAttributes="Bold" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                            <Label Text="Location:" TextColor="#6B7280" WidthRequest="100" />
                            <Label x:Name="ViewLocation" Grid.Column="1" Text="Downtown Store" FontAttributes="Bold" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                            <Label Text="Status:" TextColor="#6B7280" WidthRequest="100" />
                            <Label x:Name="ViewStatus" Grid.Column="1" Text="Pending" TextColor="#CA8A04" FontAttributes="Bold" HorizontalOptions="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Footer Buttons -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <Button Text="✓ Mark Complete" BackgroundColor="#16A34A" TextColor="White" HeightRequest="50" CornerRadius="8" Clicked="OnMarkAsDoneClicked" />
                    <Button Grid.Column="1" Text="✕ Cancel" BackgroundColor="#F3F4F6" TextColor="#4B5563" HeightRequest="50" CornerRadius="8" Clicked="OnCloseTaskDetailsClicked" />
                </Grid>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentView>