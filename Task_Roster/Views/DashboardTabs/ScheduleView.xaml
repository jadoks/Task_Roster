<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Task_Roster.Views.DashboardTabs.ScheduleView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="24,56,24,24" Spacing="20">

            <Label
                Text="Schedule"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="{StaticResource PrimaryGreen}" />

            <Label
                Text="Manage upcoming shifts and assigned tasks."
                FontSize="14"
                TextColor="{StaticResource TextMuted}" />

            <Border BackgroundColor="White" Padding="18" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Today" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />

                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="08:00" FontSize="13" TextColor="{StaticResource TextMuted}" />
                        <Label Grid.Column="1" Text="Morning Team Check-in" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextDark}" Margin="18,0,0,0" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="10:30" FontSize="13" TextColor="{StaticResource TextMuted}" />
                        <Label Grid.Column="1" Text="Task Assignment Review" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextDark}" Margin="18,0,0,0" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="15:00" FontSize="13" TextColor="{StaticResource TextMuted}" />
                        <Label Grid.Column="1" Text="End-of-day Report" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextDark}" Margin="18,0,0,0" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>