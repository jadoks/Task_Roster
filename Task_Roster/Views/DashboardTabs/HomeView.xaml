<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Task_Roster.Views.DashboardTabs.HomeView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="24,56,24,24" Spacing="22">

            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="3">
                    <Label
                        Text="Welcome back,"
                        FontSize="14"
                        TextColor="{StaticResource TextMuted}" />

                    <Label
                        Text="TaskRoster"
                        FontSize="30"
                        FontAttributes="Bold"
                        TextColor="{StaticResource PrimaryGreen}" />
                </VerticalStackLayout>

                <Border
                    Grid.Column="1"
                    WidthRequest="48"
                    HeightRequest="48"
                    BackgroundColor="{StaticResource PrimaryGreen}"
                    StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <Image
                        Source="team.svg"
                        WidthRequest="24"
                        HeightRequest="24"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Border>
            </Grid>

            <Border
                BackgroundColor="{StaticResource PrimaryGreen}"
                StrokeThickness="0"
                Padding="22">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="Today Overview"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Track your team, schedules, and daily task progress in one professional dashboard."
                        FontSize="14"
                        TextColor="#DDEEE6" />

                    <Grid ColumnDefinitions="*,*">
                        <VerticalStackLayout>
                            <Label Text="12" FontSize="32" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Tasks" FontSize="12" TextColor="#DDEEE6" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="8" FontSize="32" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Completed" FontSize="12" TextColor="#DDEEE6" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label
                Text="Quick Actions"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="{StaticResource TextDark}" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="14" RowSpacing="14">

                <Border BackgroundColor="White" Padding="18" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Image Source="schedule.svg" WidthRequest="28" HeightRequest="28" />
                        <Label Text="Schedule" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" BackgroundColor="White" Padding="18" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Image Source="team.svg" WidthRequest="28" HeightRequest="28" />
                        <Label Text="Team" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" BackgroundColor="White" Padding="18" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Image Source="home.svg" WidthRequest="28" HeightRequest="28" />
                        <Label Text="Tasks" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White" Padding="18" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Image Source="settings.svg" WidthRequest="28" HeightRequest="28" />
                        <Label Text="Settings" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>