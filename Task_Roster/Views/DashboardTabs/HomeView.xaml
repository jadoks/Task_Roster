<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Task_Roster.Views.DashboardTabs.HomeView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <ScrollView BackgroundColor="#F5F6F8">
        <VerticalStackLayout Padding="16,18,16,24" Spacing="20">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto" Padding="0,0,0,10">
                <Label
                    Text="Manager Dashboard"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="#1F2937"
                    VerticalOptions="Center" />

                <Grid Grid.Column="1" WidthRequest="30" HeightRequest="30">
                    <Image
                        Source="bell.svg"
                        WidthRequest="22"
                        HeightRequest="22"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBellTapped" />
                        </Image.GestureRecognizers>
                    </Image>

                    <Border
                        x:Name="ManagerNotificationBadge"
                        IsVisible="False"
                        BackgroundColor="#DC2626"
                        WidthRequest="17"
                        HeightRequest="17"
                        StrokeThickness="0"
                        HorizontalOptions="End"
                        VerticalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="9" />
                        </Border.StrokeShape>

                        <Label
                            x:Name="ManagerNotificationBadgeLabel"
                            Text="0"
                            FontSize="9"
                            TextColor="White"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Grid>

            <!-- Date Row -->
            <Grid ColumnDefinitions="*,Auto">
                <Label
                    x:Name="TodayDateLabel"
                    Text="Today"
                    FontSize="15"
                    FontAttributes="Bold"
                    TextColor="#1F2937"
                    VerticalOptions="Center" />

                <Border
                    Grid.Column="1"
                    BackgroundColor="#DBEAFE"
                    StrokeThickness="0"
                    Padding="12,6">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>

                    <Label
                        Text="Today"
                        FontSize="11"
                        TextColor="#2563EB" />
                </Border>
            </Grid>

            <!-- Stats Cards -->
            <Grid
                ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="12"
                RowSpacing="12">

                <Border BackgroundColor="White" Padding="14" Stroke="#E5E7EB">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border
                            WidthRequest="34"
                            HeightRequest="34"
                            BackgroundColor="#DBEAFE"
                            StrokeThickness="0"
                            VerticalOptions="Center">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="17" />
                            </Border.StrokeShape>

                            <Image Source="schedule.svg" WidthRequest="18" HeightRequest="18" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Pending Shifts" FontSize="11" TextColor="#6B7280" />
                            <Label x:Name="PendingShiftsLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Grid.Column="1" BackgroundColor="White" Padding="14" Stroke="#E5E7EB">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border
                            WidthRequest="34"
                            HeightRequest="34"
                            BackgroundColor="#FEF3C7"
                            StrokeThickness="0"
                            VerticalOptions="Center">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="17" />
                            </Border.StrokeShape>

                            <Image Source="exclamation.svg" WidthRequest="18" HeightRequest="18" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Unassigned" FontSize="11" TextColor="#6B7280" />
                            <Label x:Name="UnassignedLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Grid.Row="1" BackgroundColor="White" Padding="14" Stroke="#E5E7EB">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border
                            WidthRequest="34"
                            HeightRequest="34"
                            BackgroundColor="#DCFCE7"
                            StrokeThickness="0"
                            VerticalOptions="Center">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="17" />
                            </Border.StrokeShape>

                            <Image Source="check.svg" WidthRequest="18" HeightRequest="18" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Tasks Done" FontSize="11" TextColor="#6B7280" />
                            <Label x:Name="TasksDoneLabel" Text="0/0" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White" Padding="14" Stroke="#E5E7EB">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border
                            WidthRequest="34"
                            HeightRequest="34"
                            BackgroundColor="#F3E8FF"
                            StrokeThickness="0"
                            VerticalOptions="Center">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="17" />
                            </Border.StrokeShape>

                            <Image Source="clock.svg" WidthRequest="18" HeightRequest="18" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Staff Today" FontSize="11" TextColor="#6B7280" />
                            <Label x:Name="StaffTodayLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </Grid>

            <!-- Quick Actions -->
            <Label
                Text="Quick Actions"
                FontSize="15"
                FontAttributes="Bold"
                TextColor="#1F2937" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border BackgroundColor="White" Padding="14" Stroke="#E5E7EB">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCreateScheduleTapped" />
                    </Border.GestureRecognizers>

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Create Schedule" FontSize="13" FontAttributes="Bold" TextColor="#2563EB" />
                        <Label Text="Add shifts for your team" FontSize="11" TextColor="#6B7280" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" BackgroundColor="White" Padding="14" Stroke="#E5E7EB">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnManageTeamTapped" />
                    </Border.GestureRecognizers>

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Manage Team" FontSize="13" FontAttributes="Bold" TextColor="#2563EB" />
                        <Label Text="Update skills &amp; availability" FontSize="11" TextColor="#6B7280" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Today's Schedule -->
            <Label
                Text="Today's Schedule"
                FontSize="15"
                FontAttributes="Bold"
                TextColor="#1F2937" />

            <VerticalStackLayout x:Name="TodayScheduleLayout" Spacing="10" />

        </VerticalStackLayout>
    </ScrollView>
</ContentView>
