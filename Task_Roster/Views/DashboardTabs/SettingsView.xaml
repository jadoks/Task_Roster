<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Task_Roster.Views.DashboardTabs.SettingsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="24,56,24,24" Spacing="20">

            <Label
                Text="Settings"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="{StaticResource PrimaryGreen}" />

            <Border BackgroundColor="White" Padding="18" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="14">
                    <Label Text="Account" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />
                    <Label Text="Profile, role, notifications, and app preferences." FontSize="14" TextColor="{StaticResource TextMuted}" />

                    <Button
                        Text="Logout"
                        BackgroundColor="{StaticResource PrimaryGreen}"
                        TextColor="White"
                        CornerRadius="8"
                        Clicked="OnLogoutClicked" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>