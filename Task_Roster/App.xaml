<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="Task_Roster.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Application.Resources>
        <ResourceDictionary>

            <Color x:Key="PrimaryGreen">#165A3A</Color>
            <Color x:Key="DarkGreen">#0F3F2A</Color>
            <Color x:Key="LimeGreen">#8DFF2F</Color>
            <Color x:Key="PageBackground">#F6F7F8</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="TextDark">#143C2B</Color>
            <Color x:Key="TextMuted">#6C7A72</Color>
            <Color x:Key="BorderGreen">#8BA596</Color>
            <Color x:Key="NavDark">#191919</Color>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="Black" />
                <Setter Property="PlaceholderColor" Value="Gray" />
                <Setter Property="BackgroundColor" Value="White" />
            </Style>

            <Style TargetType="Editor">
                <Setter Property="TextColor" Value="Black" />
                <Setter Property="BackgroundColor" Value="White" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="Black" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>